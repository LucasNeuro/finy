# Copie para .env e preencha. Não commite o .env.

# ============== Redis (cache – lista de conversas, detalhe do chat, webhook) ==============
# Para o cache estar ativo, USE_REDIS deve ser true e REDIS_URL (ou REDIS_HOST) preenchido.
# No Redis Cloud: pegue a URL em "Connect" / "Public endpoint" (ex: redis://default:senha@host:port).

USE_REDIS=true
REDIS_URL=redis://default:SUA_SENHA@seu-host.redislabs.com:12345

# Alternativa: usar host/porta separados
# REDIS_HOST=seu-host.redislabs.com
# REDIS_PORT=12345
# REDIS_USERNAME=default
# REDIS_PASSWORD=SUA_SENHA

# ============== Sync automático ao reconectar o número (opcional) ==============
# Se definidos, quando o webhook recebe evento "connection" da UAZAPI, o app chama
# POST /api/channels/[id]/sync-history em background (debounce 5 min) para criar
# conversas e tickets a partir dos chats da instância.
# APP_URL=https://sua-url.onrender.com
# INTERNAL_SYNC_SECRET=uma-senha-secreta-forte

# ============== Mistral AI (geração de descrições em comunidades e grupos) ==============
# Chave em https://console.mistral.ai/. Usada no botão "Gerar com IA" nos campos de descrição.
MISTRAL_API_KEY=
